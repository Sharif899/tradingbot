# ──────────────────────────────────────────────────────────────────
#  Copy this to .env.local — never commit .env.local
#  Add the same variables in Vercel → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────

# PRIMARY: Bitget (works fully in Nigeria)
# bitget.com → Profile → API Management → Create HMAC Key
# Permissions: Read-write + Futures order + Open interest
# NEVER enable Withdraw
BITGET_API_KEY=your_bitget_api_key
BITGET_SECRET=your_bitget_secret_key
BITGET_PASSPHRASE=your_bitget_passphrase

# Which exchange to use
PRIMARY_EXCHANGE=bitget

# AI engine — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Protects the /api/trade/execute endpoint — any long random string
DASHBOARD_SECRET=make_this_long_and_random_eg_abc123xyz789def456

# Telegram alerts (highly recommended)
# 1. Message @BotFather → /newbot → copy token
# 2. Message @userinfobot → copy your chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Risk limits
MAX_RISK_PER_TRADE=0.01       # 1% per trade
MAX_DAILY_DRAWDOWN=0.05       # 5% daily loss = circuit breaker
MAX_LEVERAGE=5                 # Hard cap
MAX_OPEN_POSITIONS=3
PAPER_STARTING_CAPITAL=10000

# KEEP THIS TRUE until you've paper traded profitably for 30+ days
PAPER_TRADING=true
